# ─── Required API Keys ───────────────────────────────────────
# Get your USAJobs API key at: https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_usajobs_api_key_here

# The email you registered with USAJobs (used as User-Agent header)
USAJOBS_EMAIL=your-email@example.com

# Google Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ────────────────────────────────────────────────
# CrewAI may require an OpenAI key to be set (even if unused).
# Leave as "NA" if you're only using Gemini.
OPENAI_API_KEY=NA
